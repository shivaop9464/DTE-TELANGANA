rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all Secure Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for static schema validation and injection prevention
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isIncomingValidInstitution() {
      let inst = incoming();
      return inst.id is string && inst.id.size() <= 64
        && inst.name is string && inst.name.size() <= 256
        && inst.district is string && inst.district.size() <= 128;
    }

    function isIncomingValidUser() {
      let u = incoming();
      return u.uid is string && u.uid.size() <= 128
        && u.username is string && u.username.size() <= 128
        && u.email is string && u.email.size() <= 128
        && u.role is string && u.role.size() <= 64;
    }

    function isIncomingValidEmployee() {
      let emp = incoming();
      return emp.id is string && emp.id.size() <= 128
        && emp.name is string && emp.name.size() <= 256
        && emp.employeeId is string && emp.employeeId.size() <= 128
        && emp.mobile is string && emp.mobile.size() <= 32
        && emp.email is string && emp.email.size() <= 128
        && emp.institutionId is string && emp.institutionId.size() <= 64;
    }

    function isIncomingValidRole() {
      let r = incoming();
      return r.id is string && r.id.size() <= 64
        && r.name is string && r.name.size() <= 128;
    }

    function isIncomingValidAuditLog() {
      let log = incoming();
      return log.id is string && log.id.size() <= 128
        && log.userEmail is string && log.userEmail.size() <= 128
        && log.action is string && log.action.size() <= 128;
    }

    // 1. Roles Collection rules (Read-only static assets)
    match /roles/{roleId} {
      allow read: if true;
      allow write: if isIncomingValidRole();
    }

    // 2. Institutions Collection rules
    match /institutions/{instId} {
      allow read: if true;
      allow write: if isIncomingValidInstitution();
    }

    // 3. Users Collection rules
    match /users/{userId} {
      allow read: if true;
      allow write: if isIncomingValidUser();
    }

    // 4. Employees Collection rules
    match /employees/{empId} {
      allow read: if true;
      allow write: if isIncomingValidEmployee();
    }

    // 5. AuditLogs Collection rules (Append-only)
    match /auditLogs/{logId} {
      allow read: if true;
      allow create: if isIncomingValidAuditLog();
      allow update: if isIncomingValidAuditLog() && request.resource.data == resource.data;
      allow delete: if false;
    }
  }
}
